# Supabase — required for all server-side DB access
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Anon (public) key — required for client-side Realtime on mobile sheet
# Find it in: Supabase Dashboard → Project Settings → API → "anon public"
# This key is safe to expose; it is governed by RLS policies.
# Add to .env.local AND to Vercel → Settings → Environment Variables.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-...

# Fixed session ID for single-session use
NEXT_PUBLIC_SESSION_ID=00000000-0000-0000-0000-000000000001
